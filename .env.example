# ══════════════════════════════════════════════════════════════════
# Sakura — Environment Variables (v0.3 Agentic Consumer Protocol)
# Copy this file: cp .env.example .env.local
# ══════════════════════════════════════════════════════════════════

# ── Required: AI Engine ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude Sonnet 4.6 — powers the 4 Agent Skills

# ── Required: Solana RPC ──────────────────────────────────────────
HELIUS_API_KEY=                        # Helius API key (free tier: 50k credits/day)
# HELIUS_RPC_URL=                      # Optional: custom RPC URL (overrides HELIUS_API_KEY)
# BACKUP_RPC_URL=                      # Optional: failover RPC (auto-selected if primary is slow)

# ── Required: Sakura Intent-Execution Protocol (v0.3) ─────────────
# Protocol admin = the keypair that ran `initialize_protocol`. The
# IntentProtocol PDA is derived from this pubkey. Every user's Intent
# PDA + execute_with_intent_proof call references this admin.
SAKURA_PROTOCOL_ADMIN=                 # Server-side: base58 protocol admin pubkey
NEXT_PUBLIC_SAKURA_PROTOCOL_ADMIN=     # Client-side (same value, prefixed for Next.js exposure)
NEXT_PUBLIC_INSURANCE_PROGRAM_ID=AnszeCRFsBKmT5fBY9WywxGsZZZob8ZPFYqboYXpuYLp
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com   # or https://api.mainnet-beta.solana.com

# ── Required: Platform Agent ──────────────────────────────────────
SAKURA_AGENT_PRIVATE_KEY=[...]         # JSON array of Keypair bytes — signs Memo proofs when the agent acts on behalf of the user
SAKURA_FEE_WALLET=                     # Solana pubkey — receives MCP tool-call payments ($1 USDC each)

# ── Required: Internal Security ───────────────────────────────────
INTERNAL_API_SECRET=                   # Random 32+ char string — protects /api/agent/memo endpoint

# ── Optional: Redis (recommended for production) ─────────────────
# Without Redis, rate limiting and state are per-instance (in-memory).
# With Redis, rate limits are distributed across all serverless instances.
UPSTASH_REDIS_REST_URL=                # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=              # Upstash Redis REST token

# ── Optional: Public URLs ────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # App base URL (auto-set on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # OG image / SEO canonical URL

# ── Optional: Monitoring ──────────────────────────────────────────
STATS_API_KEY=                         # Protects /api/stats endpoint (use Authorization: Bearer header)

# ── Optional: OKX Wallet ──────────────────────────────────────────
# OKX_PROJECT_ID=                      # OKX wallet connect project ID
# OKX_API_KEY=                         # OKX API key
# OKX_SECRET_KEY=                      # OKX API secret
# OKX_PASSPHRASE=                      # OKX API passphrase

# ── Optional: Faucet route (/api/faucet) ──────────────────────────
# Required if you want the "Claim test tokens" button on /testing to work.
# JSON array of 64 bytes — the admin keypair that is the USDC mint authority
# for Sakura's devnet test USDC (mint 7rEh…Li3). Can be the same as
# ~/.config/solana/id.json for local dev. For Vercel, paste the file
# contents as the value.
# ⚠️ DEVNET ONLY — never set mainnet admin key here.
SAKURA_FAUCET_ADMIN_KEYPAIR=[]
